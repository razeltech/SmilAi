# ==========================================
# SmilAI - Production Environment Variables
# ==========================================

# 1. Strict Local Model Enforcement
# Prevents models from downloading to global system directories (like C:\Users\...)
# ALL models must live strictly within the project repository.
HF_HOME="./models/hf_cache"
OLLAMA_MODELS="./models/ollama_cache"

# 2. Database Paths
# The unified SQLite database for both Node UI and Python RAG Engine
SQLITE_DB_PATH="./database/smilai.db"

# 3. Server Configuration
PYTHON_SERVER_PORT=8000
NODE_SERVER_PORT=3000

# 4. Fallback / Test APIs (If# Only fully offline variables allowed
